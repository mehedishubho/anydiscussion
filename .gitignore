# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/.idea
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# pnpm-only — never commit npm's package-lock.json (Pitfall 5)
package-lock.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local tooling / runtime state (not shared across the team)
.claude/settings.local.json
.claude/.gsd-profile
.claude/worktrees/
.codex/
.agents/
