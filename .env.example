# Copy to .env.local for local dev. Real R2 secrets go in .env.local (gitignored).
# Coolify injects staging/prod environment variables at deploy time.

# Primary database (Postgres 16 via docker-compose)
DATABASE_URL=postgres://postgres:postgres@localhost:5435/anydiscussion

# Throwaway DB for clean-room migration test (postgres-test service, port 5436)
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5436/anydiscussion_test

# CDN base URL — MinIO default for local dev; Coolify injects https://cdn.anydiscussion.com in staging/prod (D-12)
NEXT_PUBLIC_CDN_URL=http://localhost:9000

# S3-compatible storage config — MinIO defaults (local dev); R2 in staging/prod
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=anydiscussion-media
# MinIO requires path-style addressing (true); R2 uses virtual-hosted style (false) — Pitfall 3
S3_FORCE_PATH_STYLE=true
