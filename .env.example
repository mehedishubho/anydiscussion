# .env.example — documents every env var the app + Better Auth consumes.
# Copy to .env.local (gitignored) and fill in real values for local dev.
# Staging/prod values are injected via Coolify.

# === Database ===
# Primary dev DB (postgres service in docker-compose.yml, port 5435).
DATABASE_URL=postgresql://anydiscussion:125524@localhost:5435/anydiscussion
# Throwaway DB for the clean-room migration drift test (postgres-test service, port 5436).
TEST_DATABASE_URL=postgresql://anydiscussion:125524@localhost:5436/anydiscussion_test

# === Better Auth (Phase 2 — Plan 02-01 Task 1b) ===
# Generate with: openssl rand -base64 32  (>=32 chars, high entropy).
BETTER_AUTH_SECRET=
# Base URL of the app (no trailing slash). Dev: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated trusted origins for CSRF/origin validation (D-21).
# Prod: https://anydiscussion.com,https://staging.anydiscussion.com
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# === Resend (email — AUTH-06/07; helper ships in Plan 02-03) ===
# Get from https://resend.com/api-keys. Leave empty for local dev (sendEmail stubs to console).
RESEND_API_KEY=
# From-address. Must be a verified domain in Resend dashboard.
# Dev: use Resend's sandbox sender (onboarding@resend.dev) — no DNS needed.
# Prod: no-reply@mail.anydiscussion.com
EMAIL_FROM=onboarding@resend.dev

# D-04 — DKIM/SPF/DMARC + a mail from-domain on anydiscussion.com are a DEPLOY
# dependency (Phase 7). Without these, AUTH-06/07 emails land in spam or are
# rejected. Dev works fine with Resend's shared sandbox sender above.

# === S3-compatible storage (Phase 1 — lib/r2) ===
# MinIO defaults for local dev; R2 in staging/prod.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=anydiscussion-media
# MinIO requires path-style addressing (true); R2 uses virtual-hosted style (false) — Pitfall 3
S3_FORCE_PATH_STYLE=true

# === CDN (Phase 1 — image-loader) ===
# MinIO default for local dev; Coolify injects https://cdn.anydiscussion.com in staging/prod (D-12)
NEXT_PUBLIC_CDN_URL=http://localhost:9000

# D-25 credential encryption key (Plan 04-05). 32-byte base64 — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Runtime env var (Coolify) — NOT NEXT_PUBLIC. Required for /dashboard/settings/storage
# save (the local provider keeps working without it; only the encrypted providers need it).
SETTINGS_ENCRYPTION_KEY=
